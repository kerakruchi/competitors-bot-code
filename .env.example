# Скопируйте этот файл в .env и заполните значения:
# cp .env.example .env

# Обязательно: токен Telegram-бота (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# Опционально: OpenAI API ключ для AI-классификации и кратких описаний
# Получить на: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Опционально: путь к базе данных (по умолчанию news_monitor.db)
# DB_PATH=news_monitor.db

# Опционально: расписание проверок (по умолчанию 12:00 Europe/Moscow)
# SCHEDULE_HOUR=12
# SCHEDULE_MINUTE=0
# SCHEDULE_TZ=Europe/Moscow
